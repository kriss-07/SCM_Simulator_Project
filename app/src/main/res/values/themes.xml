<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.SCMSimulator" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#008B8B</item>
        <item name="colorPrimaryVariant">#005B5B</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#FF03DAC5</item>
        <item name="colorSecondaryVariant">#FF018786</item>
        <item name="colorOnSecondary">#000000</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- App background -->
        <item name="android:windowBackground">@drawable/app_bg</item>
        <!-- Text Colors -->
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#FFFFFF</item>
        <!-- Custom Spinners -->
        <item name="android:spinnerStyle">@style/CustomSpinnerStyle</item>
    </style>

    <style name="CustomSpinnerStyle" parent="Widget.AppCompat.Spinner">
        <item name="android:background">@drawable/bg_spinner</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">32dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:popupBackground">#1A1A1A</item> <!-- Dark popup background overlay -->
    </style>
</resources>
