<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:background="@drawable/bg_spinner"
    android:padding="12dp">

    <!-- Portrait Area -->
    <FrameLayout
        android:id="@+id/portrait_container"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/img_combat_aura"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/anim_aura"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/img_combat_portrait"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/img_pilot_standing"
            android:scaleType="centerInside" />

        <ImageView
            android:id="@+id/img_combat_shield"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/anim_shield"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Stats Area -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
        app:layout_constraintStart_toEndOf="@id/portrait_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/text_combat_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Health Bar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp">
            
            <ProgressBar
                android:id="@+id/progress_combat_hp"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:progressDrawable="@android:drawable/progress_horizontal"
                android:progressTint="#FF4444"
                android:progress="100" />
            
            <TextView
                android:id="@+id/text_combat_hp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="100/100"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:textStyle="bold"/>
        </FrameLayout>

        <!-- Energy Bar -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp">

            <ProgressBar
                android:id="@+id/progress_combat_energy"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:progressDrawable="@android:drawable/progress_horizontal"
                android:progressTint="#44AAFF"
                android:progress="100" />

            <TextView
                android:id="@+id/text_combat_energy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="100/100"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:textStyle="bold"/>
        </FrameLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
